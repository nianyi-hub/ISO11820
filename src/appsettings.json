{
  "Database": {
    "Provider": "Sqlite",
    "SqlitePath": "Data\\ISO11820.db"
  },
  "Hardware": {
    "ConstPower": 2048,
    "PidTemperature": 750,
    "SensorProtocol": "ModbusRtu"
  },
  "Simulation": {
    "EnableSimulation": true,
    "SimulateSensors": true,
    "SimulatePidController": true,
    "InitialFurnaceTemp": 720.0,
    "TargetFurnaceTemp": 750.0,
    "HeatingRatePerSecond": 40.0,
    "TempFluctuation": 0.5,
    "StableThreshold": 3.0,
    "SimulateFlame": false,
    "SurfaceFollowRatio": 0.3,
    "CenterFollowRatio": 0.25,
    "SurfaceApproachRate": 0.02,
    "CenterApproachRate": 0.01
  },
  "FileStorage": {
    "BaseDirectory": "Data",
    "TestDataDirectory": "Data\\TestData"
  },
  "Report": {
    "OutputDirectory": "Data\\Reports",
    "EnablePdfExport": true
  },
  "Logging": {
    "LogDirectory": "Logs",
    "LogFileName": "ISO11820_{Date}.log",
    "MinimumLevel": "Information"
  }
}
